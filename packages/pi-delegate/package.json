{
  "name": "pi-delegate",
  "version": "0.1.0",
  "description": "Pi extension: delegate tool for spawning child Pi agents",
  "type": "module",
  "exports": {
    ".": "./src/parent/index.ts"
  },
  "files": ["src", "agents"],
  "keywords": ["pi", "extension", "delegate", "ai-agent"],
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.4.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./src/parent/index.ts",
      "./src/delegate-provider/index.ts"
    ]
  },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "typebox": "~1.1",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
