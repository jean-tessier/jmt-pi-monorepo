{
  "name": "pi-delegate",
  "version": "0.1.0",
  "description": "Pi extension: delegate tool for spawning child Pi agents",
  "type": "module",
  "exports": {
    ".": "./src/parent/index.ts"
  },
  "files": ["src", "agents"],
  "keywords": ["pi", "extension", "delegate", "ai-agent"],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "yaml": "^2.4.0"
  },
  "peerDependencies": {
    "pi": "0.79.8"
  },
  "pi": {
    "extensions": [
      "./src/parent/index.ts",
      "./src/delegate-provider/index.ts"
    ]
  },
  "engines": { "node": ">=18" },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}
