{
  "name": "pi-structured-output",
  "version": "0.1.0",
  "description": "Pi extension: structured output capture for child Pi agents",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src"],
  "keywords": ["pi", "extension", "structured-output", "ai-agent"],
  "license": "MIT",
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "typebox": "^1.3.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "typebox": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "engines": { "node": ">=18" },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
